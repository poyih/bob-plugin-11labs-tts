        {
            "identifier": "apiKey",
            "type": "text",
            "title": "API Key",
            "defaultValue": "",
            "textConfig": {
                "type": "secure",
                "placeholderText": "sk_..."
            },
            "desc": "在 elevenlabs.io/app/settings/api-keys 创建，需要开启 text_to_speech 权限。"
        },
        {
            "identifier": "model",
            "type": "menu",
            "title": "模型",
            "defaultValue": "eleven_flash_v2_5",
            "menuValues": [
                {
                    "title": "Flash v2.5 — 最快、最便宜（32 语言，推荐划词朗读）",
                    "value": "eleven_flash_v2_5"
                },
                {
                    "title": "Multilingual v2 — 音质最稳、情感自然（29 语言）",
                    "value": "eleven_multilingual_v2"
                },
                {
                    "title": "v3 — 表现力最强、支持 70+ 语言（较慢、较贵）",
                    "value": "eleven_v3"
                },
                {
                    "title": "Flash v2 — 仅英语，超低延迟",
                    "value": "eleven_flash_v2"
                }
            ],
            "desc": "Flash 系列延迟约 75ms，适合即时朗读；Multilingual v2 和 v3 音质更好但更慢。"
