        {
            "identifier": "customVoiceId",
            "type": "text",
            "title": "自定义 Voice ID",
            "defaultValue": "",
            "textConfig": {
                "type": "visible",
                "placeholderText": "留空则使用上面选中的音色"
            },
            "desc": "填了就优先生效。Voice ID 在 elevenlabs.io 音色详情页的「Voice ID」处复制。"
        },
        {
            "identifier": "outputFormat",
            "type": "menu",
            "title": "音频格式",
            "defaultValue": "mp3_44100_128",
            "menuValues": [
                {
                    "title": "MP3 44.1kHz 128kbps（默认）",
                    "value": "mp3_44100_128"
                },
                {
                    "title": "MP3 44.1kHz 64kbps（更省流量）",
                    "value": "mp3_44100_64"
                },
                {
                    "title": "MP3 22.05kHz 32kbps（最快、最省）",
                    "value": "mp3_22050_32"
                },
                {
                    "title": "MP3 44.1kHz 192kbps（需 Creator 及以上订阅）",
                    "value": "mp3_44100_192"
                }
            ],
            "desc": "朗读场景 32~64kbps 通常已经够用，能明显缩短等待时间。"
        },
        {
            "identifier": "stability",
            "type": "menu",
            "title": "稳定性",
            "defaultValue": "",
            "menuValues": [
                {
                    "title": "跟随音色自带设置",
                    "value": ""
                },
                {
                    "title": "0.0 — 更有情绪起伏",
                    "value": "0"
                },
                {
                    "title": "0.5 — 自然",
                    "value": "0.5"
                },
                {
                    "title": "1.0 — 最稳定、最平淡",
                    "value": "1"
                }
            ],
            "desc": "留空表示不覆盖你在 ElevenLabs 网站上给该音色保存的设置。"
        },
        {
            "identifier": "similarityBoost",
            "type": "menu",
            "title": "音色相似度",
            "defaultValue": "",
            "menuValues": [
                {
                    "title": "跟随音色自带设置",
                    "value": ""
                },
                {
                    "title": "0.5",
                    "value": "0.5"
                },
                {
                    "title": "0.75",
                    "value": "0.75"
                },
                {
                    "title": "1.0",
                    "value": "1"
                }
            ],
            "desc": "越高越贴近原始音色，过高可能放大底噪。"
        },
        {
            "identifier": "style",
            "type": "menu",
            "title": "风格强度",
            "defaultValue": "",
            "menuValues": [
                {
                    "title": "跟随音色自带设置",
                    "value": ""
                },
                {
                    "title": "0.0 — 关闭（最快）",
                    "value": "0"
                },
                {
                    "title": "0.3",
                    "value": "0.3"
                },
                {
                    "title": "0.6",
                    "value": "0.6"
                }
            ],
            "desc": "放大原音色的说话风格，非 0 会增加延迟。"
        },
        {
            "identifier": "speed",
            "type": "menu",
            "title": "语速",
            "defaultValue": "",
            "menuValues": [
                {
                    "title": "跟随音色自带设置",
                    "value": ""
                },
                {
                    "title": "0.8 倍 — 慢",
                    "value": "0.8"
                },
                {
                    "title": "0.9 倍",
                    "value": "0.9"
                },
                {
                    "title": "1.0 倍 — 正常",
                    "value": "1.0"
                },
                {
                    "title": "1.1 倍",
                    "value": "1.1"
                },
                {
                    "title": "1.2 倍 — 快",
                    "value": "1.2"
                }
            ],
            "desc": "偏离 1.0 太多会影响音质。"
        },
        {
            "identifier": "speakerBoost",
            "type": "menu",
            "title": "Speaker Boost",
            "defaultValue": "",
            "menuValues": [
                {
                    "title": "跟随音色自带设置",
                    "value": ""
                },
                {
                    "title": "开启",
                    "value": "true"
                },
                {
                    "title": "关闭（延迟更低）",
                    "value": "false"
                }
            ],
            "desc": "增强与原始说话人的相似度，会略微增加延迟。"
        }
